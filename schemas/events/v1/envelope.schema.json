{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rootcellar.dev/schemas/events/v1/envelope.schema.json",
  "title": "RootCellar Event Envelope v1",
  "type": "object",
  "required": [
    "event_name",
    "event_version",
    "timestamp",
    "severity",
    "trace_id",
    "span_id",
    "context",
    "metrics",
    "payload"
  ],
  "properties": {
    "event_name": { "type": "string", "minLength": 1 },
    "event_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "severity": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error"]
    },
    "trace_id": { "type": "string", "format": "uuid" },
    "span_id": { "type": "string", "format": "uuid" },
    "parent_span_id": { "type": ["string", "null"], "format": "uuid" },
    "session_id": { "type": ["string", "null"], "format": "uuid" },
    "workbook_id": { "type": ["string", "null"], "format": "uuid" },
    "txn_id": { "type": ["string", "null"], "format": "uuid" },
    "context": { "type": "object" },
    "metrics": { "type": "object" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}